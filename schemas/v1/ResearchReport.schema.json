{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supersystem/schemas/v1/ResearchReport",
  "title": "ResearchReport",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "workflow_id",
    "correlation_id",
    "claims",
    "sources",
    "extracted_requirements",
    "freshness"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "report_id": { "type": "string" },
    "workflow_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "text", "source_ids"],
        "properties": {
          "claim_id": { "type": "string" },
          "text": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "uri", "captured_at"],
        "properties": {
          "source_id": { "type": "string" },
          "uri": { "type": "string" },
          "captured_at": { "type": "string" },
          "checksum": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "extracted_requirements": { "type": "array", "items": { "type": "string" } },
    "freshness": {
      "type": "object",
      "required": ["required", "status"],
      "properties": {
        "required": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pass", "warn", "fail", "blocked"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
