{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StatusViewContract",
  "type": "object",
  "required": [
    "correlation_id",
    "workflow_class",
    "autonomy_mode",
    "current_state",
    "run_status",
    "last_transition_at",
    "why",
    "blocked_reason",
    "next_action"
  ],
  "properties": {
    "correlation_id": { "type": "string" },
    "workflow_class": { "type": "string" },
    "autonomy_mode": { "type": "string" },
    "current_state": { "type": "string" },
    "run_status": { "type": "string", "enum": ["running", "blocked"] },
    "last_transition_at": { "type": "string", "format": "date-time" },
    "why": { "type": "string" },
    "blocked_reason": { "type": ["string", "null"] },
    "next_action": { "type": "string" }
  },
  "additionalProperties": false
}
