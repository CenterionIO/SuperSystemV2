{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityRetentionRedactionPolicy",
  "type": "object",
  "required": [
    "version",
    "retention_days",
    "immutable_artifacts",
    "redaction_levels",
    "redaction_methods",
    "pii_field_patterns",
    "secrets_field_patterns",
    "audit_log_scope"
  ],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "retention_days": { "type": "integer", "minimum": 1 },
    "immutable_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "redaction_levels": {
      "type": "array",
      "items": { "type": "string", "enum": ["none", "standard", "strict"] },
      "minItems": 3
    },
    "redaction_methods": {
      "type": "array",
      "items": { "type": "string", "enum": ["mask", "hash", "drop"] },
      "minItems": 3
    },
    "pii_field_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "secrets_field_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "audit_log_scope": {
      "type": "object",
      "required": ["include_events", "exclude_fields"],
      "properties": {
        "include_events": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "exclude_fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
