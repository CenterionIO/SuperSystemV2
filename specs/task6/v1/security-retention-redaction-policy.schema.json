{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityRetentionRedactionPolicy",
  "type": "object",
  "required": [
    "version",
    "retention_days",
    "immutable_artifacts",
    "redaction_levels",
    "pii_field_patterns",
    "secrets_field_patterns",
    "audit_log_scope"
  ],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "retention_days": { "type": "integer", "minimum": 1 },
    "immutable_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "redaction_levels": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "pii_field_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "secrets_field_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "audit_log_scope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
