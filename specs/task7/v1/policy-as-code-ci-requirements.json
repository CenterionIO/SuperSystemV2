{
  "version": "v1",
  "required_workflows": [
    "stage-gates",
    "policy-validation",
    "schema-validation"
  ],
  "required_commands": [
    "python3 specs/task6/v1/validate-task6.py",
    "python3 specs/task7/v1/validate-task7.py",
    "zsh tools/run_all_gates.sh"
  ],
  "fail_conditions": {
    "any_validator_nonzero": true,
    "missing_required_workflow": true,
    "missing_required_command": true,
    "golden_path_failure": true,
    "schema_validation_failure": true
  }
}
